* text=auto

# Unity YAML assets should stay text and keep LF line endings for cleaner diffs.
*.cs text eol=lf
*.asmdef text eol=lf
*.asmref text eol=lf
*.shader text eol=lf
*.hlsl text eol=lf
*.cginc text eol=lf
*.unity text eol=lf
*.prefab text eol=lf
*.asset text eol=lf
*.meta text eol=lf
*.mat text eol=lf
*.controller text eol=lf
*.anim text eol=lf
*.inputactions text eol=lf
*.json text eol=lf
*.md text eol=lf
*.txt text eol=lf

# Binary assets.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.tga binary
*.psd binary
*.fbx binary
*.blend binary
*.wav binary
*.mp3 binary
*.mp4 binary
*.mov binary
*.zip binary
